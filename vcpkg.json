name: Build Rust EXE

on:
  push:
[{"main" ]
  pull_request:
    branches: [ "main" ]
  workflow_dispatch:

env:
  CARGO_TERM_COLOR: always

jobs:
  build:
    runs-on: windows-latest

    steps:
    - name: Checkout Code
      uses: actions/checkout@v4

    # --- 步骤 1：安装 vcpkg 并强制安装静态库 ---
    - name: Setup vcpkg (Classic Mode)
      run: |
        # 1. 克隆 vcpkg
        git clone https://github.com/Microsoft/vcpkg.git
        cd vcpkg
        .\bootstrap-vcpkg.bat
        
        # 2. 【关键】配置清华镜像源
        # 解决下载超时问题
        @"
        {
          "registries": [
            {
              "kind": "git",
              "repository": "https://mirrors.tuna.tsinghua.edu.cn/git/vcpkg/ports.git",
              "packages": [ "*" ]
            }
          ]
        }
        "@ | Out-File -FilePath "vcpkg-configuration.json" -Encoding utf8

        # 3. 【关键】手动安装静态库
        # 显式指定 :x64-windows-static，不使用清单模式自动安装
        .\vcpkg install openssl:x64-windows-static
        .\vcpkg install libvpx:x64-windows-static
        .\vcpkg install libyuv:x64-windows-static
        
        # 4. 设置环境变量
        echo "VCPKG_ROOT=${{ github.workspace }}/vcpkg" | Out-File -FilePath $env:GITHUB_ENV -Encoding utf8 -Append
        echo "${{ github.workspace }}/vcpkg" | Out-File -FilePath $env:GITHUB_PATH -Encoding utf8 -Append

    # --- 步骤 2：编译 Rust 代码 ---
    - name: Build Release
      run: cargo build --release --verbose
      env:
        VCPKG_ROOT: ${{ github.workspace }}/vcpkg
        # 强制指定使用静态库
        VCPKG_DEFAULT_TRIPLET: x64-windows-static

    # --- 步骤 3：上传成果 ---
    - name: Upload Artifact
      uses: actions/upload-artifact@v4
      with:
        name: rust-app-exe
        path: target/release/rustby9527.exe
